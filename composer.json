{
    "name": "themehybrid/hybrid-events",
    "description": "The Events package.",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "wordpress"
    ],
    "authors": [
        {
            "name": "Theme Hybrid",
            "email": "themehybrid@gmail.com",
            "homepage": "https://themehybrid.com",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/themehybrid/hybrid-events",
    "support": {
        "issues": "https://github.com/themehybrid/hybrid-events/issues",
        "forum": "https://themehybrid.com/board/forums/hybrid-core"
    },
    "require": {
        "php": "^8.1",
        "themehybrid/hybrid-core": "dev-dev as 6.0",
        "themehybrid/hybrid-contracts": "dev-dev as 1.0",
        "themehybrid/hybrid-tools": "dev-dev as 1.0"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/themehybrid/hybrid-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/saas786/hybrid-contracts"
        },
        {
            "type": "vcs",
            "url": "https://github.com/saas786/hybrid-tools"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Hybrid\\Events\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
